{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "job": "node src/jobs/phaseTransitionJob.js",
    "env:run": "node scripts/runWithEnv.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy:supabase": "node scripts/runWithEnv.js .env prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "test": "cross-env NODE_ENV=test vitest run",
    "test:watch": "cross-env NODE_ENV=test vitest",
    "test:supabase": "cross-env NODE_ENV=test node scripts/runWithEnv.js .env vitest run --testTimeout=10000"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^6.4.1",
    "@supabase/supabase-js": "^2.101.1",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "nodemon": "^3.1.9",
    "prisma": "^6.4.1",
    "supertest": "^7.1.4",
    "vitest": "^4.1.0"
  }
}
