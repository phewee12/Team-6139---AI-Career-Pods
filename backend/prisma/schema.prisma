generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

enum PodVisibility {
  PUBLIC
  PRIVATE
}

enum PodMembershipStatus {
  ACTIVE
  PENDING
  REJECTED
}

enum PodMembershipRole {
  MEMBER
  ADMIN
}

model User {
  id                  String           @id @default(uuid())
  email               String           @unique
  passwordHash        String?
  fullName            String?
  fieldOfStudy        String?
  careerStage         String?
  targetTimeline      String?
  avatarUrl           String?
  avatarData          Bytes?
  avatarMimeType      String?
  authProvider        AuthProvider     @default(LOCAL)
  googleId            String?          @unique
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  createdPods         Pod[]            @relation("PodCreatedBy")
  podMemberships      PodMembership[]  @relation("PodMembershipUser")
  authoredPodPosts    PodPost[]        @relation("PodPostAuthor")
  reviewedMemberships PodMembership[]  @relation("PodMembershipReviewedBy")
  podCheckIns         PodCheckIn[]
  podReflections      PodReflection[]
  podCelebrations     PodCelebration[]
  notifications       Notification[]

  @@index([fieldOfStudy])
  @@index([careerStage])
}

model Pod {
  id              String           @id @default(uuid())
  slug            String           @unique
  name            String
  description     String
  focusArea       String
  visibility      PodVisibility    @default(PUBLIC)
  isDefault       Boolean          @default(true)
  createdById     String?
  createdByUser   User?            @relation("PodCreatedBy", fields: [createdById], references: [id])
  memberships     PodMembership[]
  posts           PodPost[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  podCheckIns     PodCheckIn[]
  podReflections  PodReflection[]
  podCelebrations PodCelebration[]
  ritualDay       String?          @default("MONDAY")
  ritualHour      Int?             @default(9)
  podPhase        PodPhase?
  notifications   Notification[]

  @@index([focusArea])
  @@index([visibility])
  @@index([createdById])
}

model PodPost {
  id        String   @id @default(uuid())
  podId     String
  authorId  String
  content   String
  pod       Pod      @relation(fields: [podId], references: [id], onDelete: Cascade)
  author    User     @relation("PodPostAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([podId, createdAt])
  @@index([authorId])
}

model PodMembership {
  id             String              @id @default(uuid())
  podId          String
  userId         String
  role           PodMembershipRole   @default(MEMBER)
  status         PodMembershipStatus @default(PENDING)
  requestedAt    DateTime            @default(now())
  joinedAt       DateTime?
  reviewedAt     DateTime?
  reviewedById   String?
  pod            Pod                 @relation(fields: [podId], references: [id], onDelete: Cascade)
  user           User                @relation("PodMembershipUser", fields: [userId], references: [id], onDelete: Cascade)
  reviewedByUser User?               @relation("PodMembershipReviewedBy", fields: [reviewedById], references: [id])
  onboardedAt    DateTime?
  introMessage   String?

  @@unique([podId, userId])
  @@index([podId, status])
  @@index([userId, status])
  @@index([reviewedById])
}

model PodCheckIn {
  id            String        @id @default(uuid())
  podId         String
  userId        String
  weekStartDate DateTime
  status        CheckInStatus @default(PENDING)
  notes         String?
  goals         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  pod  Pod  @relation(fields: [podId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([podId, userId, weekStartDate])
  @@index([podId, weekStartDate])
  @@index([userId])
}

model PodReflection {
  id            String   @id @default(uuid())
  podId         String
  userId        String
  weekStartDate DateTime
  content       String   @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  pod                 Pod                  @relation(fields: [podId], references: [id], onDelete: Cascade)
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  reflectionSentiment ReflectionSentiment?

  @@index([podId, weekStartDate])
  @@index([userId])
}

model PodCelebration {
  id            String   @id @default(uuid())
  podId         String
  userId        String
  weekStartDate DateTime
  title         String
  description   String   @db.Text
  createdAt     DateTime @default(now())

  pod  Pod  @relation(fields: [podId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([podId, weekStartDate])
}

enum CheckInStatus {
  PENDING
  COMPLETED
  LATE
  SKIPPED
}

model PodPhase {
  id             String    @id @default(uuid())
  podId          String    @unique
  currentPhase   PhaseType @default(MONDAY_SET)
  phaseStartedAt DateTime  @default(now())
  nextPhaseAt    DateTime
  timezone       String    @default("UTC")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  pod Pod @relation(fields: [podId], references: [id], onDelete: Cascade)

  @@index([podId])
  @@index([currentPhase])
}

model Notification {
  id          String           @id @default(uuid())
  userId      String
  podId       String
  type        NotificationType @default(PHASE_REMINDER)
  title       String
  message     String
  scheduledAt DateTime
  sentAt      DateTime?
  readAt      DateTime?
  createdAt   DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  pod  Pod  @relation(fields: [podId], references: [id], onDelete: Cascade)

  @@index([userId, sentAt])
  @@index([podId, scheduledAt])
  @@index([scheduledAt])
}

model ReflectionSentiment {
  id           String        @id @default(uuid())
  reflectionId String        @unique
  sentiment    SentimentType
  score        Float
  keywords     String[]
  analyzedAt   DateTime      @default(now())

  reflection PodReflection @relation(fields: [reflectionId], references: [id], onDelete: Cascade)

  @@index([sentiment])
  @@index([analyzedAt])
}

enum PhaseType {
  MONDAY_SET
  WEDNESDAY_CHECK
  FRIDAY_REFLECT
  WEEKEND_BREAK
}

enum NotificationType {
  PHASE_REMINDER
  CHECK_IN_REMINDER
  REFLECTION_REMINDER
  CELEBRATION_ALERT
}

enum SentimentType {
  POSITIVE
  NEUTRAL
  NEGATIVE
}
