enum AuthProvider {
  LOCAL
  GOOGLE
}

enum PodVisibility {
  PUBLIC
  PRIVATE
}

enum PodMembershipStatus {
  ACTIVE
  PENDING
  REJECTED
}

enum PodMembershipRole {
  OWNER
  MEMBER
  ADMIN
}

enum CheckInStatus {
  PENDING
  COMPLETED
  LATE
  SKIPPED
}

enum PhaseType {
  MONDAY_SET
  WEDNESDAY_CHECK
  FRIDAY_REFLECT
  WEEKEND_BREAK
}

enum NotificationType {
  PHASE_REMINDER
  CHECK_IN_REMINDER
  REFLECTION_REMINDER
  CELEBRATION_ALERT
  MEMBER_JOINED
  RESUME_REVIEW_RECEIVED
  NUDGE_RECEIVED
  NUDGE_REPLIED
  QUIET_MODE_NOTICE
}

enum ResumeReviewStatus {
  OPEN
  CLOSED
  WITHDRAWN
}

enum ResumeRecommendation {
  STRONG_YES
  YES_WITH_EDITS
  NEEDS_MAJOR_REVISION
}

enum SentimentType {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                        String                    @id @default(uuid())
  email                     String                    @unique
  passwordHash              String?
  fullName                  String?
  fieldOfStudy              String?
  careerStage               String?
  targetTimeline            String?
  avatarUrl                 String?
  authProvider              AuthProvider              @default(LOCAL)
  googleId                  String?                   @unique
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt
  avatarData                Bytes?
  avatarMimeType            String?
  notifications             Notification[]
  notificationsSent         Notification[]            @relation("NotificationSender")
  createdPods               Pod[]                     @relation("PodCreatedBy")
  podCelebrations           PodCelebration[]
  podCheckIns               PodCheckIn[]
  reviewedMemberships       PodMembership[]           @relation("PodMembershipReviewedBy")
  podMemberships            PodMembership[]           @relation("PodMembershipUser")
  authoredPodPosts          PodPost[]                 @relation("PodPostAuthor")
  podReflections            PodReflection[]
  resumeReviewFilesUploaded PodResumeFile[]           @relation("ResumeFileUploader")
  resumeReviewFeedbackGiven PodResumeReviewFeedback[] @relation("ResumeFeedbackReviewer")
  nudgesSent                Nudge[]                   @relation("NudgeFrom")
  nudgesReceived            Nudge[]                   @relation("NudgeTo")
  podQuietModes             QuietMode[]
  accountabilityMetrics     AccountabilityMetric[]
  resumeReviewRequests      PodResumeReviewRequest[]  @relation("ResumeRequestOwner")
  engagementMetrics         EngagementMetrics[]
  engagementScores          EngagementScores[]
  generatedBiweeklySummaries PodBiweeklySummary[]      @relation("PodBiweeklySummaryGeneratedBy")

  @@index([fieldOfStudy])
  @@index([careerStage])
}

model Pod {
  id                    String                   @id @default(uuid())
  slug                  String                   @unique
  name                  String
  description           String
  focusArea             String
  visibility            PodVisibility            @default(PUBLIC)
  isDefault             Boolean                  @default(true)
  createdById           String?
  createdByUser         User?                    @relation("PodCreatedBy", fields: [createdById], references: [id])
  memberships           PodMembership[]
  posts                 PodPost[]
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  podCheckIns           PodCheckIn[]
  podReflections        PodReflection[]
  podCelebrations       PodCelebration[]
  ritualDay             String?                  @default("MONDAY")
  ritualHour            Int?                     @default(9)
  podPhase              PodPhase?
  notifications         Notification[]
  resumeReviewRequests  PodResumeReviewRequest[]
  nudges                Nudge[]
  quietModes            QuietMode[]
  accountabilityMetrics AccountabilityMetric[]
  engagementMetrics     EngagementMetrics[]
  engagementScores      EngagementScores[]
  biweeklySummaries     PodBiweeklySummary[]

  @@index([focusArea])
  @@index([visibility])
  @@index([createdById])
}

model PodBiweeklySummary {
  id           String   @id @default(uuid())
  podId        String
  windowStartAt DateTime
  windowEndAt  DateTime
  summaryText  String   @db.Text
  sourceCounts Json?
  generatedById String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  pod         Pod   @relation(fields: [podId], references: [id], onDelete: Cascade)
  generatedBy User? @relation("PodBiweeklySummaryGeneratedBy", fields: [generatedById], references: [id], onDelete: SetNull)

  @@unique([podId, windowStartAt])
  @@index([podId, windowStartAt])
  @@index([generatedById])
}

model PodPost {
  id        String   @id @default(uuid())
  podId     String
  authorId  String
  content   String
  pod       Pod      @relation(fields: [podId], references: [id], onDelete: Cascade)
  author    User     @relation("PodPostAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([podId, createdAt])
  @@index([authorId])
}

model PodMembership {
  id             String              @id @default(uuid())
  podId          String
  userId         String
  role           PodMembershipRole   @default(MEMBER)
  status         PodMembershipStatus @default(PENDING)
  requestedAt    DateTime            @default(now())
  joinedAt       DateTime?
  reviewedAt     DateTime?
  reviewedById   String?
  pod            Pod                 @relation(fields: [podId], references: [id], onDelete: Cascade)
  user           User                @relation("PodMembershipUser", fields: [userId], references: [id], onDelete: Cascade)
  reviewedByUser User?               @relation("PodMembershipReviewedBy", fields: [reviewedById], references: [id])
  onboardedAt    DateTime?
  introMessage   String?

  @@unique([podId, userId])
  @@index([podId, status])
  @@index([userId, status])
  @@index([reviewedById])
}

model PodCheckIn {
  id            String        @id @default(uuid())
  podId         String
  userId        String
  weekStartDate DateTime
  status        CheckInStatus @default(PENDING)
  notes         String?
  goals         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  pod  Pod  @relation(fields: [podId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([podId, userId, weekStartDate])
  @@index([podId, weekStartDate])
  @@index([userId])
}

model PodReflection {
  id            String   @id @default(uuid())
  podId         String
  userId        String
  weekStartDate DateTime
  content       String   @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  pod                 Pod                  @relation(fields: [podId], references: [id], onDelete: Cascade)
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  reflectionSentiment ReflectionSentiment?

  @@index([podId, weekStartDate])
  @@index([userId])
}

model PodCelebration {
  id            String   @id @default(uuid())
  podId         String
  userId        String
  weekStartDate DateTime
  title         String
  description   String   @db.Text
  createdAt     DateTime @default(now())

  pod  Pod  @relation(fields: [podId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([podId, weekStartDate])
}

model PodPhase {
  id             String    @id @default(uuid())
  podId          String    @unique
  currentPhase   PhaseType @default(MONDAY_SET)
  phaseStartedAt DateTime  @default(now())
  nextPhaseAt    DateTime
  timezone       String    @default("UTC")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  pod Pod @relation(fields: [podId], references: [id], onDelete: Cascade)

  @@index([podId])
  @@index([currentPhase])
}

model Notification {
  id          String           @id @default(uuid())
  userId      String
  senderId    String?
  podId       String
  type        NotificationType @default(PHASE_REMINDER)
  title       String
  message     String
  scheduledAt DateTime
  sentAt      DateTime?
  readAt      DateTime?
  createdAt   DateTime         @default(now())

  user   User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  sender User? @relation("NotificationSender", fields: [senderId], references: [id], onDelete: SetNull)
  pod    Pod   @relation(fields: [podId], references: [id], onDelete: Cascade)

  @@index([userId, sentAt])
  @@index([senderId, sentAt])
  @@index([podId, scheduledAt])
  @@index([scheduledAt])
}

model ReflectionSentiment {
  id           String        @id @default(uuid())
  reflectionId String        @unique
  sentiment    SentimentType
  score        Float
  keywords     String[]
  analyzedAt   DateTime      @default(now())

  reflection PodReflection @relation(fields: [reflectionId], references: [id], onDelete: Cascade)

  @@index([sentiment])
  @@index([analyzedAt])
}

enum NudgeType {
  TEMPLATE
  CUSTOM
}

enum NudgeQuickReply {
  BUSY_OKAY
  NEED_SUPPORT
  CATCH_UP
  LETS_CHAT
}

model PodResumeReviewRequest {
  id          String             @id @default(uuid())
  podId       String
  requesterId String
  status      ResumeReviewStatus @default(OPEN)
  title       String
  targetRole  String?
  context     String?            @db.Text
  closedAt    DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  pod       Pod                       @relation(fields: [podId], references: [id], onDelete: Cascade)
  requester User                      @relation("ResumeRequestOwner", fields: [requesterId], references: [id], onDelete: Cascade)
  file      PodResumeFile?
  feedback  PodResumeReviewFeedback[]

  @@index([podId, status, createdAt])
  @@index([requesterId, createdAt])
}

model PodResumeFile {
  id               String   @id @default(uuid())
  requestId        String   @unique
  uploadedById     String
  storageBucket    String
  storagePath      String   @unique
  originalFileName String
  mimeType         String
  sizeBytes        Int
  uploadedAt       DateTime @default(now())

  request    PodResumeReviewRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  uploadedBy User                   @relation("ResumeFileUploader", fields: [uploadedById], references: [id], onDelete: Cascade)

  @@index([uploadedById, uploadedAt])
}

model PodResumeReviewFeedback {
  id                    String                @id @default(uuid())
  requestId             String
  reviewerId            String
  overallScore          Int?
  impactAndResultsScore Int?
  roleFitScore          Int?
  atsClarityScore       Int?
  strengths             String                @db.Text
  improvements          String                @db.Text
  lineLevelSuggestions  String?               @db.Text
  finalComments         String?               @db.Text
  recommendation        ResumeRecommendation?
  submittedAt           DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  request  PodResumeReviewRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  reviewer User                   @relation("ResumeFeedbackReviewer", fields: [reviewerId], references: [id], onDelete: Cascade)

  @@unique([requestId, reviewerId])
  @@index([reviewerId, submittedAt])
  @@index([requestId, submittedAt])
}

/// Maps to table `nudges` — template vs custom, optional custom `message`, read/response tracking.
model Nudge {
  id               String           @id @default(uuid())
  podId            String           @map("pod_id")
  fromUserId       String           @map("from_user_id")
  toUserId         String           @map("to_user_id")
  nudgeType        NudgeType        @map("nudge_type")
  message          String?          @db.Text
  templateId       String?          @map("template_id")
  sentAt           DateTime         @default(now()) @map("sent_at")
  readAt           DateTime?        @map("read_at")
  response         NudgeQuickReply?
  respondedAt      DateTime?        @map("responded_at")
  sentimentScore   Float?           @map("sentiment_score")
  sentimentLabel   SentimentType?   @map("sentiment_label")
  flaggedForReview Boolean          @default(false) @map("flagged_for_review")
  sentHourUtc      Int?             @map("sent_hour_utc")
  sentDowUtc       Int?             @map("sent_dow_utc")

  pod      Pod  @relation(fields: [podId], references: [id], onDelete: Cascade)
  fromUser User @relation("NudgeFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User @relation("NudgeTo", fields: [toUserId], references: [id], onDelete: Cascade)

  @@index([podId, sentAt])
  @@index([fromUserId, toUserId, sentAt])
  @@index([toUserId, sentAt])
  @@index([fromUserId, sentAt])
  @@index([toUserId, readAt])
  @@map("nudges")
}

/// Maps to table `quiet_mode`.
model QuietMode {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  podId      String    @map("pod_id")
  startDate  DateTime  @map("start_date")
  endDate    DateTime? @map("end_date")
  reason     String?
  autoNotify Boolean   @default(true) @map("auto_notify")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  pod  Pod  @relation(fields: [podId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, podId])
  @@map("quiet_mode")
}

/// Weekly per-user per-pod rollups for accountability dashboards.
model AccountabilityMetric {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  podId          String   @map("pod_id")
  weekStartDate  DateTime @map("week_start_date")
  nudgesReceived Int      @default(0) @map("nudges_received")
  nudgesSent     Int      @default(0) @map("nudges_sent")
  responseRate   Float?   @map("response_rate")

  pod  Pod  @relation(fields: [podId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, podId, weekStartDate])
  @@index([podId, weekStartDate])
  @@map("accountability_metrics")
}

model EngagementMetrics {
  id                    String   @id @default(cuid())
  userId                String
  podId                 String
  weekStartDate         DateTime
  messagesCount         Int      @default(0)
  goalsCompleted        Int      @default(0)
  applicationsSubmitted Int      @default(0)
  checkinsCompleted     Int      @default(0)
  reflectionsCompleted  Int      @default(0)
  celebrationsCreated   Int      @default(0)
  resumeReviewsGiven    Int      @default(0)
  nudgesSent            Int      @default(0)
  nudgesReplied         Int      @default(0)
  lastActiveAt          DateTime @default(now())
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  pod  Pod  @relation(fields: [podId], references: [id], onDelete: Cascade)

  @@unique([userId, podId, weekStartDate])
  @@index([userId, podId, weekStartDate])
}

model EngagementScores {
  id            String   @id @default(cuid())
  userId        String
  podId         String
  weekStartDate DateTime
  score         Int
  level         String // 'LOW', 'MEDIUM', 'HIGH'
  previousScore Int?
  trend         String? // 'UP', 'DOWN', 'STABLE'
  calculatedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  pod  Pod  @relation(fields: [podId], references: [id], onDelete: Cascade)

  @@unique([userId, podId, weekStartDate])
  @@index([userId, podId, calculatedAt])
}
